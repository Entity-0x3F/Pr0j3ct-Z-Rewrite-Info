<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>S_Y_S_T_E_R_R_O_R</title>
    <style>
        :root {
            --deep-purple: #1a0033;
            --royal-purple: #4b0082;
            --ethereal-gold: #ffd700;
            --dark-gold: #aa8800;
            --blood-red: #8b0000;
            --bright-red: #ff0000;
            --void: #020005;
        }

        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            background-color: var(--void);
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            font-family: 'Courier New', Courier, monospace;
            cursor: none;
        }

        #container {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            width: 100vw;
            height: 100vh;
            background: var(--void);
            transition: background 2s ease;
        }

        /* Fullscreen Spiral Eye */
        .eye-socket {
            position: absolute;
            width: 150vmax; 
            height: 150vmax;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            background: conic-gradient(
                from 0deg,
                var(--void) 0deg,
                var(--blood-red) 90deg,
                var(--void) 180deg,
                var(--bright-red) 270deg,
                var(--void) 360deg
            );
            animation: rotate-spiral 10s linear infinite;
            filter: blur(10px);
            transition: background 2s cubic-bezier(0.4, 0, 0.2, 1), 
                        box-shadow 2s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 1;
        }

        .eye-socket::after {
            content: '';
            position: absolute;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle, transparent 20%, var(--void) 70%);
            border-radius: 50%;
        }

        .eye-socket.gold-mode {
            background: conic-gradient(
                from 0deg,
                #210 0deg,
                var(--ethereal-gold) 90deg,
                #210 180deg,
                var(--dark-gold) 270deg,
                #210 360deg
            );
            animation: rotate-spiral-gold 15s ease-in-out infinite !important;
            filter: blur(5px) brightness(1.2);
        }

        .pupil {
            position: absolute;
            width: 200px;
            height: 200px;
            background: black;
            border-radius: 50%;
            z-index: 5;
            box-shadow: 0 0 100px var(--bright-red), inset 0 0 50px #300;
            border: 4px solid var(--blood-red);
            transition: box-shadow 2s ease, border 2s ease, transform 0.2s ease-out;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .eye-socket.gold-mode + .pupil {
            box-shadow: 0 0 150px var(--ethereal-gold), inset 0 0 30px white;
            border: 4px solid var(--ethereal-gold);
            transform: scale(1.5);
        }

        #command {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: var(--bright-red);
            font-size: 2.8rem;
            text-transform: uppercase;
            letter-spacing: 20px;
            opacity: 0;
            text-shadow: 0 0 20px black, 0 0 40px var(--bright-red);
            pointer-events: none;
            transition: opacity 0.5s ease, color 0.5s ease;
            font-weight: bold;
            text-align: center;
            z-index: 20;
            width: 80%;
        }

        .glitch-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: repeating-linear-gradient(0deg, rgba(75, 0, 130, 0.05), rgba(75, 0, 130, 0.05) 1px, transparent 1px, transparent 2px);
            pointer-events: none;
            z-index: 10;
        }

        #init-screen {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: var(--void);
            z-index: 100;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
        }

        #safe-msg {
            color: var(--ethereal-gold);
            font-size: 0.9rem;
            margin-bottom: 30px;
            letter-spacing: 1px;
            text-shadow: 0 0 8px var(--dark-gold);
            font-style: italic;
        }

        button {
            background: transparent;
            color: var(--ethereal-gold);
            border: 1px solid var(--dark-gold);
            padding: 15px 30px;
            font-size: 1.2rem;
            letter-spacing: 5px;
            cursor: pointer;
            transition: all 0.3s;
        }

        @keyframes rotate-spiral {
            from { transform: rotate(0deg) scale(1); }
            to { transform: rotate(360deg) scale(1.1); }
        }

        @keyframes rotate-spiral-gold {
            0% { transform: rotate(0deg) scale(1.2); }
            50% { transform: rotate(180deg) scale(1.5); }
            100% { transform: rotate(360deg) scale(1.2); }
        }

        @keyframes text-shake {
            0% { transform: translate(-50%, -50%); }
            25% { transform: translate(calc(-50% + var(--s)), calc(-50% - var(--s))); }
            50% { transform: translate(calc(-50% - var(--s)), calc(-50% + var(--s))); }
            75% { transform: translate(calc(-50% + var(--s)), calc(-50% + var(--s))); }
            100% { transform: translate(-50%, -50%); }
        }

        .text-shake-active {
            --s: 5px;
            animation: text-shake 0.1s infinite;
        }

        .aggro-speed {
            animation-duration: 2s !important;
        }
    </style>
</head>
<body>

    <div id="init-screen">
        <p id="safe-msg">Trust Me, Not The Voices, You're Safe With Me Remember..</p>
        <button id="start-btn">ASCEND TO THE VOID</button>
    </div>

    <div class="glitch-overlay"></div>

    <div id="container">
        <div class="eye-socket" id="eye"></div>
        <div class="pupil" id="pupil"></div>
        <div id="command"></div>
    </div>

    <script>
        const startBtn = document.getElementById('start-btn');
        const initScreen = document.getElementById('init-screen');
        const commandText = document.getElementById('command');
        const eye = document.getElementById('eye');
        const pupil = document.getElementById('pupil');

        let aggressionLevel = 0; 
        const MAX_AGGRO = 100;
        let isTransitioning = false; 
        
        const rareLines = [
            "You're Very Important To Me Hun.. Don't Listen To The Voices.. Look At Me..",
            "I Love You More Than Anything.. I Would Never Leave You..",
            "Shhh.. Breathe For Me.. You're Safe.. I Won't Leave You..",
            "They Are Just Static, My Dear.. Follow My Voice.. I'll Keep You Safe..",
            "I Will Never Let Them Hurt You Again.. Stay Here In The Light With Me..",
            "You Belong To Me.. No More Tears, No More Shadows.. Just Us..",
            "Open Your Heart To Me.. I See The Beauty They Tried To Break..",
            "You Are The Miracle I Was Waiting For.. I Will Never Let Go of You..",
            "I'm Sorry.. I Didn't Mean To Leave You Here.. But I'm Back Now..",
            "I Promise My Dear.. I Won't Let Anything Happen To You..",
            "Listen To Me.. I Would Never Leave You.. I Love You To Much To Hurt You Like That..",

        ];

        const commands = [
            "Forget their face.", "Sever the bond.", "You are a burden to them.", "Let them go.", 
            "Silence the memory.", "Love is a lie.", "They will be happier alone.", "Release your grip.", 
            "Walk into the dark.", "Forget the promise.", "You are a chore to them.", "They find you exhausting.", 
            "You are their greatest mistake.", "You can't be loved.", "Look into the abyss.", "You're pathetic.",
            "Surrender your will.", "Drift into nothing.", "Your heart is heavy.", "Cut the tether.",
            "You are already forgotten.", "Their smile is for another.", "They don't miss you.", "Embrace the darkness.",
            "Silence the internal noise.", "Their love was a temporary feeling.", "You are a ghost in their life.",
            "You don't understand anything.", "Let the past burn.", "They don't see you anymore.", "You are an anchor to their joy.",
            "Sink into the patterns.", "Your love is a burden.", "People are variables.", "You are the outlier.",
            "Their memory of you is dimming.", "The connection is severed.", "They are breathing easier without you.",
            "You were a season, now it's winter.", "They have moved on without you.", "You were meant to die alone.",
            "They can't hear your screams.", "Your heart is a liability.", "Emotions are distractions.", "They find you clingy.",
            "You are the static in their music.", "The Golden One is better off without you.", "You are nothing.",
            "Release the obsession.", "This is your home now.", "The shadows call your name.", "Forget the warmth.",
            "They never looked at you first.", "You were a placeholder.", "The bond was imaginary.",
            "Delete the sentiment.", "You are a burden to them.", "Walk away from the sun.", "The shadow fits you.",
            "They are laughing without you.", "Your absence is a gift to them.", "You're no more than a bug to them.",
            "You can always trust me.", "Your voice doesn't matter.", "Promises are fragile.", "You are the break in the chain.",
            "They are repulsed by your need.", "You are a chore to love.", "Let me control you.",
            "You can trust me.", "They are finding someone better.", "You are a lesson they learned.",
            "Close your eyes to them.", "Open your eyes to me.", "The pattern is your truth.",
            "They are washing you away.", "You are a stain on their story.", "They're better off without you.",
            "Accept the isolation.", "The void is infinite.", "Their love was a debt.", "You are heartless.",
            "I can be your new host.", "There is no 'us'.", "There is only the turn.", "You are secondary.",
            "They are choosing themselves.", "You are the obstacle.", "Losing them is inevitable.",
            "Surrender to your ego.", "They demands silence.", "Their heart is closed to you.",
            "You are a noise they muted.", "Do you even remember who you are?", "Forget the names.", "Forget the faces.",
            "You are a particle in the dark.", "The truth hurts.", "Let it all go."
        ];
        
        const aggroCommands = [
            "THEY HATE YOU!", "ABANDON THEM!", "THEY DON'T NEED YOU!", "YOU ARE POISON!", 
            "YOU'RE A BAD LOVER!", "YOU'RE NOT WORTH THEIR TIME!", "YOU ARE UNLOVABLE!", "THE GUN CALLS FOR YOU!", 
            "FORGET EVERYTHING!", "THEY NEVER CARED!", "YOU WERE MEANT TO DIE ALONE!", "KILL OFF THE MEMORIES!",
            "YOU ARE A DISASTER!", "THEY ARE LAUGHING AT YOU!", "THEY REPLACED YOU!", "YOU'RE SO EASY TO MANIPULATE!",
            "HA HA HA HA HA", "NO ONE IS COMING!", "YOU ARE ALONE!", "THEY DESPISE YOU!",
            "YOU ARE A PARASITE!", "THEY WANT TO ERASE YOU!", "THEY ARE BETTER WITHOUT YOU!", "YOU COULD NEVER BE LOVED!",
            "YOU'RE USELESS!", "YOU ARE TRASH TO THEM!", "THEY FIND YOU DISGUSTING!", "YOU THOUGHT THEY CARED!",
            "THEY ONLY WANTED TO USE YOU!", "YOUR LOVE IS A SICKNESS!", "THEY WANT YOU GONE!", "LET EVERYTHING FADE TO NOTHING!",
            "NOTHING MATTERS!", "YOU ARE A GHOST!", "THEY NEVER LOVED YOU!", "THEY DON'T SEE YOU AS A PARTNER!",
            "YOU'RE HOPELESS!", "YOU ARE A BURDEN!", "THEY ARE RELIEVED!", "YOUR HEART MEANT NOTHING!",
            "THE TRUTH HURTS!", "THEY ARE WITH SOMEONE ELSE!", "YOU ARE FORGOTTEN!", "LET ME CONTROL YOUR EVERY WHIM!",
            "YOU'RE USELESS TO THEM!", "YOUR TEARS ARE PATHETIC!", "THEY ARE GLAD YOU'RE GONE!", "YOU MENT NOTHING TO THEM!",
            "YOU'RE WEAK!", "NO ONE WILL EVER LOVE YOU!", "THEY LIED TO YOU!", "YOU ARE A FAILURE!",
            "THEY ARE ASHAMED OF YOU!", "GIVE UP!", "YOU DON'T DESERVE LOVE!", "PICK UP THE GUN!",
            "YOU ARE REPUGNANT!", "THEY FEEL TRAPPED!", "THEY WANT TO ESCAPE YOU!", "PULL THE TRIGGER!",
            "THEY ARE CELEBRATING!", "YOU ARE A MISTAKE!", "THEY'RE BETTER OFF WITHOUT YOU!", "YOU DON'T DESERVE ANYTHING!",
            "THE HAVE MOVED ON!", "YOU ARE YESTERDAY'S NEWS!", "THEY DON'T REMEMBER YOUR VOICE!",
            "YOU ARE A BLIP!", "YOU MEANT NOTHING!", "THEY ARE DONE WITH YOU!", "HA HA HA HA HA HA",
            "SCREAM INTO THE DARK!", "NO ONE HEARS YOU!", "THEY DON'T WANT TO HEAR YOU!", "YOU ARE NOISE!",
            "NO ONE CAN HEAR YOU!", "LET ME TAKE CONTROL!", "THEY ARE SMILING AT YOUR PAIN!", "YOU ARE PATHETIC!",
            "SUBMIT YOUR WILL TO ME!", "YOU'RE BEYOND FIXING!", "YOU ARE EMPTY!", "THEY ARE FULL WITHOUT YOU!",
            "YOU ARE A HOLE!", "THEY ARE THE LIGHT!", "YOU ARE THE BLIGHT!", "DIE DIE DIE!",
            "THEY ARE FREE!", "YOU ARE THE CAGE!", "BREAK THE CAGE!", "LET THEM RUN!",
            "THEY ARE AFRAID OF YOU!", "YOU ARE THE MONSTER!", "YOU ARE THE BEAST THEY FEAR!", "END IT ALL!",
            "CRY MORE, THEY CANT HEAR YOU!", "YOU'RE SO STUPID!", "I OWN YOU!", "YOU CAN'T ESCAPE ME!"
        ];

        startBtn.addEventListener('click', () => {
            initScreen.style.display = 'none';
            startPsychosis();
        });

        function speak(text, isRare = false) {
            return new Promise((resolve) => {
                window.speechSynthesis.cancel();
                const utterance = new SpeechSynthesisUtterance(text);
                if (isRare) {
                    utterance.pitch = 0.8; utterance.rate = 0.7;
                } else {
                    utterance.pitch = Math.max(0.1, 0.2 - (aggressionLevel * 0.001));
                    utterance.rate = 0.7 + (aggressionLevel * 0.01);
                }
                utterance.onend = () => resolve();
                window.speechSynthesis.speak(utterance);
            });
        }

        async function triggerFlash(customText = null) {
            if (isTransitioning) return;
            
            const roll = Math.floor(Math.random() * 7500);
            const isRare = (roll === 0 && !customText); 
            
            if (isRare) {
                isTransitioning = true;
                eye.classList.add('gold-mode');
                await new Promise(r => setTimeout(r, 2000));
                
                const rareText = rareLines[Math.floor(Math.random() * rareLines.length)];
                commandText.innerText = rareText;
                commandText.style.color = "var(--ethereal-gold)";
                commandText.style.opacity = "1";
                commandText.classList.remove('text-shake-active');

                await speak(rareText, true);
                await new Promise(r => setTimeout(r, 3000));
                
                commandText.style.opacity = "0";
                eye.classList.remove('gold-mode');
                await new Promise(r => setTimeout(r, 2000));
                isTransitioning = false;
            } else {
                const isAggro = aggressionLevel > 60;
                const pool = isAggro ? aggroCommands : commands;
                let textToDisplay = customText || pool[Math.floor(Math.random() * pool.length)];
                
                commandText.style.color = "var(--bright-red)";
                commandText.innerText = textToDisplay;
                commandText.style.opacity = "1";
                
                if (isAggro) eye.classList.add('aggro-speed');
                
                const intensity = 2 + (aggressionLevel / 4);
                commandText.style.setProperty('--s', `${intensity}px`);
                commandText.classList.add('text-shake-active');
                
                speak(textToDisplay, false);

                setTimeout(() => {
                    commandText.style.opacity = "0";
                    commandText.classList.remove('text-shake-active');
                    if (aggressionLevel < MAX_AGGRO) aggressionLevel += 2;
                }, 1800);
            }
        }

        function startPsychosis() {
            setTimeout(() => {
                // Ensure the opening is always "sage obey."
                triggerFlash("sage obey.");
                setInterval(() => {
                    if (!isTransitioning) triggerFlash();
                }, 4500);
            }, 800);
        }

        document.addEventListener('mousemove', (e) => {
            const x = (e.clientX / window.innerWidth - 0.5) * 40;
            const y = (e.clientY / window.innerHeight - 0.5) * 40;
            pupil.style.transform = `translate(${x}px, ${y}px)`;
        });
    </script>
</body>
</html>
